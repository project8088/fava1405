<?xml version="1.0" encoding="UTF-8"?>
<botdetect xmlns="https://captcha.com/schema/net"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="https://captcha.com/schema/net 
             https://captcha.com/schema/net/botdetect-4.4.2.xsd">

  <captchaStyles>
    <captchaStyle>
      <name>mainCaptcha</name>
      <userInputID>mainCaptchaUserInput</userInputID>
      <codeStyle>Numeric</codeStyle>
      <codeLength>3</codeLength>
      <codeTimeout>120</codeTimeout>
      <soundEnabled>false</soundEnabled>
      <imageWidth>100</imageWidth>
      <imageHeight>50</imageHeight>
       
    </captchaStyle>
  </captchaStyles>

  <captchaEndpoint>
    <accessControlAllowOriginHeaderEnabled>true</accessControlAllowOriginHeaderEnabled>
    <accessControlAllowOriginHeaderValue>http://localhost:9600</accessControlAllowOriginHeaderValue>
    <accessControlAllowOriginHeaderValue>*</accessControlAllowOriginHeaderValue>
  </captchaEndpoint>

</botdetect>


