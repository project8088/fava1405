{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./out-tsc/app",
    "types": [],
    "paths": {
      "@core/*": ["./src/app/core/*"],
      "@app/*": ["./src/app/*"]
    }
  },
  "angularCompilerOptions": {
    "strictTemplates": true
  },
  "include": [
    "./src/main.ts",
    "./src/app/pages/card/**/*.ts"
    // "src/**/*.ts"
  ],
  "exclude": ["src/**/*.spec.ts"]
}
