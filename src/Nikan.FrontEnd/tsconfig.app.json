{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./out-tsc/app",
    "types": [],
    "paths": {
      "@core/*": ["./src/app/core/*"],
      "@app/*": ["./src/app/*"]
    }
  },
  "angularCompilerOptions": {
    "strictTemplates": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["src/**/*.spec.ts"]
}
